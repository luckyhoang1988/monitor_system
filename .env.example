# Sao chép file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên git

# Django
SECRET_KEY=django-insecure-thay-bang-key-ngau-nhien-dai-50-ky-tu
DJANGO_SETTINGS_MODULE=config.settings.development

# Mã hóa credentials (SSH password, SNMP community) trong DB
# Tạo key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=thay-bang-key-tu-lenh-tren

# Database (chỉ cần cho production)
DB_NAME=monitor_db
DB_USER=monitor_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Chu kỳ poll (giây) — mọi mục 120s trừ HyperV. Để trống = dùng default.
POLL_NETWORK_INTERVAL_SECS=120
POLL_PING_INTERVAL_SECS=120
POLL_HYPERV_INTERVAL_SECS=300
ALERT_EVAL_INTERVAL_SECS=120

# SNMP request — giữ nhỏ để thiết bị offline không treo worker khi chu kỳ ngắn.
SNMP_TIMEOUT_SECS=5
SNMP_RETRIES=1

# Alert — Email (SMTP)
SMTP_HOST=smtp.company.local
SMTP_PORT=587
SMTP_USER=monitor@company.local
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=monitor@company.local
ALERT_EMAIL_RECIPIENTS=admin@company.local,noc@company.local

# Alert — Telegram Bot
TELEGRAM_BOT_TOKEN=123456789:ABCDEFabcdefGHIJKL-xxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100123456789

# SNMP communities (tham khảo — lưu trong Device model, không ở đây)
# SNMP_COMMUNITY_CISCO=public
# SNMP_COMMUNITY_HW=public

# HyperV WinRM (tham khảo — lưu trong Device model)
# WINRM_USER=DOMAIN\monitor_user
# WINRM_PASS=your_winrm_password

# Data retention
METRICS_RETENTION_DAYS=90

# Production only
ALLOWED_HOSTS=192.168.1.100,monitor.company.local
